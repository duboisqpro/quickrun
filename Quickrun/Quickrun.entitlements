<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!--
        Quickrun intentionally runs WITHOUT the app sandbox so that it can
        execute arbitrary user scripts.  See spec.md §6 for rationale.
    -->
    <key>com.apple.security.app-sandbox</key>
    <false/>
</dict>
</plist>
